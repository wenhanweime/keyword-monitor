<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pot.keyword-monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>-lc</string>
        <string>cd /Users/pot/Documents/keyword-monitor &amp;&amp; /usr/bin/python3 monitor.py</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key>
        <integer>17</integer>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/pot/Documents/keyword-monitor</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/pot/.bun/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/pot/Documents/keyword-monitor/logs/monitor.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/pot/Documents/keyword-monitor/logs/monitor.err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
